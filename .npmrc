# Do not auto-install peerDependencies. The `@useauthio/react` peer is not yet
# published to npm, and pnpm's auto-install-peers would 404 on it during a
# normal install (breaking CI before the first react release). `next`, `react`,
# and `react-dom` needed for build/typecheck/test are provided as
# devDependencies instead. This file is not published (not in package.json
# "files"), so it does not affect consumers.
auto-install-peers=false
