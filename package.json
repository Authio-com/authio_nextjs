{
  "name": "@useauthio/nextjs",
  "version": "0.4.3",
  "description": "Next.js adapter for Authio: middleware, RSC helpers, and Provider.",
  "author": "Authio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Authio-com/authio_nextjs.git"
  },
  "homepage": "https://authio.com",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsup src/index.ts src/server.ts --format esm --dts --clean --out-dir dist",
    "dev": "tsup src/index.ts src/server.ts --format esm --dts --watch --out-dir dist",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@useauthio/react": "*",
    "next": ">=14",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@useauthio/react": {
      "optional": true
    }
  },
  "dependencies": {
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.0",
    "next": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1"
    }
  }
}
